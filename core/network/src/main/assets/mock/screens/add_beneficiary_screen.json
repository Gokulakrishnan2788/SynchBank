{
  "screenId": "add_beneficiary",
  "version": "1.0",
  "metadata": { "title": "Add Beneficiary", "analyticsTag": "add_beneficiary_screen" },
  "header": {
    "id": "header_bar",
    "type": "HEADER_BAR",
    "visible": true,
    "props": {
      "title": "Architect",
      "showBack": true,
      "backAction": "NAVIGATE_BACK",
      "showSearch": false,
      "showNotification": true,
      "notificationAction": "HEADER_NOTIFICATION"
    }
  },
  "layout": { "type": "SCROLL", "padding": { "horizontal": 20, "vertical": 16 } },
  "components": [
    { "id": "security_label", "type": "TEXT", "visible": true, "props": { "text": "SECURITY & IDENTITY", "style": "LABEL", "color": "TealAccent" } },
    { "id": "spacer_1", "type": "SPACER", "visible": true, "props": { "height": 8 } },
    { "id": "page_title", "type": "TEXT", "visible": true, "props": { "text": "Add Beneficiary", "style": "HEADING1", "color": "NavyPrimary" } },
    { "id": "spacer_2", "type": "SPACER", "visible": true, "props": { "height": 8 } },
    { "id": "page_subtitle", "type": "TEXT", "visible": true, "props": { "text": "Securely save account details for faster recurring transfers and payments.", "style": "BODY", "color": "MediumGray" } },
    { "id": "spacer_3", "type": "SPACER", "visible": true, "props": { "height": 28 } },
    {
      "id": "beneficiary_form", "type": "ADD_BENEFICIARY_FORM", "visible": true,
      "props": {
        "fields": [
          { "id": "account_name", "label": "ACCOUNT NAME", "hint": "John Doe", "helperText": "Must match the legal name on the destination account.", "inputType": "TEXT" },
          { "id": "bank_name", "label": "BANK NAME", "hint": "Select Institution", "fieldType": "DROPDOWN", "options": ["NED", "SBI", "ICICI", "HDFC", "HSBC", "IOB", "Citibank", "Deutsche Bank", "Barclays", "Standard Chartered", "JPMorgan Chase", "HSBC Global"], "inputType": "TEXT" },
          { "id": "account_number", "label": "ACCOUNT NUMBER", "hint": "0000000000", "inputType": "NUMBER" },
          { "id": "nickname", "label": "NICKNAME (OPTIONAL)", "hint": "e.g. Rent Payment", "helperText": "A short name to help you identify this contact.", "inputType": "TEXT" }
        ]
      }
    },
    { "id": "spacer_4", "type": "SPACER", "visible": true, "props": { "height": 24 } },
    {
      "id": "verification_card", "type": "VERIFICATION_CARD", "visible": true,
      "props": {
        "title": "Secure Verification",
        "description": "Architect verifies all beneficiary accounts against global banking standards to prevent fraud."
      }
    },
    { "id": "spacer_5", "type": "SPACER", "visible": true, "props": { "height": 24 } },
    {
      "id": "save_btn", "type": "BUTTON", "visible": true,
      "props": { "label": "Save Beneficiary", "style": "PRIMARY" },
      "action": "SUBMIT_BENEFICIARY"
    },
    { "id": "spacer_end", "type": "SPACER", "visible": true, "props": { "height": 80 } }
  ],
  "actions": {
    "HEADER_NOTIFICATION": { "type": "NAVIGATE", "destination": "notifications" },
    "SUBMIT_BENEFICIARY": { "type": "NAVIGATE", "destination": "submit_beneficiary" }
  }
}
